# Frontend / Next.js environment template
# Copy this file to .env.local and fill in the secrets before running locally

# Runtime
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API routing (points to local backend by default)
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Privy authentication
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Optional demo/testing helpers
#DEMO_TOKEN=test_token_for_e2e
#LOG_LEVEL=debug
