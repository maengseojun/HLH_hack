{
  "version": 2,
  "routes": [
    { "src": "/healthz", "dest": "/api/healthz" },
    { "src": "/readyz", "dest": "/api/readyz" },
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Powered-By", "value": "CoreIndex" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/jobs/smoke",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "app/api/*/route.js": {
      "maxDuration": 30
    }
  }
}