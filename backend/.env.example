# HyperIndex Backend environment template
# Copy to backend/.env and provide real values before running locally or deploying

# Runtime
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
AUTH_MODE=bearer
DEMO_BEARER_TOKEN=hyperindex-demo-token-2024
DEMO_TOKEN=test_token_for_e2e

# Shared services
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Hyperliquid + Hypercore endpoints
HYPERLIQUID_API_URL=https://api.testnet.hyperliquid.xyz
INFO_API_URL=https://api.testnet.hyperliquid.xyz/info
REQUEST_TIMEOUT_MS=10000

HYPERCORE_RPC_URL=https://testnet.hypercore.hyperliquid.xyz
HYPERCORE_WALLET_KEY=0xyour_testnet_private_key
HYPERCORE_TIMEOUT=30000
CORE_WRITER_ADDRESS=0x0000000000000000000000000000000000000000
MAX_SLIPPAGE_BPS=200
MAX_LEVERAGE=50
MIN_NOTIONAL_USD=1

# Settlement chain configuration (Arbitrum Sepolia by default)
CHAIN_RPC_URL=https://arb-sepolia.arbitrum.io/rpc
CHAIN_ID=421614
USDC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
PLATFORM_FEE_BPS=0

# Caching and rate limiting
CACHE_TTL_SECONDS=60
CACHE_STALE_TTL=180
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Optional smoke/regression test overrides
#SMOKE_BASE_URL=http://localhost:3000/v1
